# clang-tidy config for GridTV — drives an informational REPORT in CI (uploaded
# as a build artifact), NOT a hard gate. clang-tidy's clang-analyzer-* is the
# same engine as scan-build (a hard gate), and several of its bucket checks are
# noisy with patterns that are INTENTIONAL in this VLC plugin:
#   - __PLUGIN__ / MODULE_STRING : required by the VLC module ABI
#   - empty catch(...) {}        : deliberate, so a C++ throw can never escape
#                                  into VLC's C ABI and terminate the process
#   - C-style casts in plugin glue : idiomatic next to VLC's own C-style casts
# So we keep the check list tight (real memory/correctness issues only) and
# leave WarningsAsErrors unset. The hard memory-safety gates are scan-build +
# cppcheck + ASAN (see the `audit` job in .github/workflows/build.yml).
Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  cppcoreguidelines-slicing,
  misc-*,
  performance-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-empty-catch,
  -bugprone-reserved-identifier,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -misc-include-cleaner,
  -misc-non-private-member-variables-in-classes,
  -misc-no-recursion,
  -misc-use-internal-linkage,
  -misc-use-anonymous-namespace,
  -misc-const-correctness,
  -misc-confusable-identifiers,
  -modernize-*,
  -readability-*,
  -performance-enum-size,
  -performance-unnecessary-value-param,
  -performance-unnecessary-copy-initialization,
  -performance-no-int-to-ptr,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-bounds-avoid-unchecked-container-access
HeaderFilterRegex: '/gridtv/'
